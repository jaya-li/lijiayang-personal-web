# Copy to .env and fill in (never commit .env)
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Strong general chat model (default: gpt-4o). Optional: gpt-4-turbo, etc.
OPENAI_CHAT_MODEL=gpt-4o

# Server port (Render/Railway 等平台会自动注入 PORT)
PORT=3000

# 网页托管在「别的域名」时必填：允许跨域的来源列表（英文逗号分隔，无空格或带空格均可）
# 例：GitHub Pages 填 https://你的名.github.io ；自定义域填 https://www.你的域.com
ALLOWED_ORIGINS=

# 部署在 Render / Heroku 等反向代理后面时建议设为 1，限流才会按真实访客 IP 计算
TRUST_PROXY=

# 知识库目录（可选，绝对路径或相对「当前工作目录」解析——建议写绝对路径）
# 不设则默认使用项目内的 knowledge/（仅读取 .md）；可把额外笔记放在任意文件夹
# KNOWLEDGE_DIR=/Users/you/Downloads
#
# 多个目录（英文逗号分隔），会合并检索，source 会带文件夹名前缀
# KNOWLEDGE_DIRS=/path/to/repo/knowledge,/Users/you/Downloads
